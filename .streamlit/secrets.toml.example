# .streamlit/secrets.toml.example
# Copia este archivo como secrets.toml y rellena tus valores.
# NUNCA subas secrets.toml a GitHub — está en .gitignore.
#
# En Streamlit Community Cloud, estos valores se configuran en:
# App → Settings → Secrets (pega el contenido directamente)

GITHUB_TOKEN   = "ghp_TU_TOKEN_AQUI"
GITHUB_REPO    = "tu_usuario/rrss-dashboard"
GITHUB_DB_PATH = "data/rrss.db"
